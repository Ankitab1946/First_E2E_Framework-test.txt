APP_NAME=Data Dictionary Streamlit Admin
APP_ENV=LOCAL
APP_DEBUG=false
API_BASE_URL=http://localhost:8502/api/v1
USE_API_FOR_FILTERS=true

# Environment selector values visible in the Streamlit side panel.
APP_ENVIRONMENTS=LOCAL,DEV,UAT,PROD
SELECTED_ENVIRONMENT=LOCAL

# Default SQL Server settings. These are overwritten when matching ENV_<ENV>_* values exist.
SQLSERVER_SERVER=localhost\SQLEXPRESS
SQLSERVER_DATABASE=PRJ_DB
# SQL Server authentication mode. Supported values:
# windows = logged-in Windows user / Integrated authentication
# keytab  = Kerberos authentication using krb5.conf + keytab
# sql     = SQL username/password
SQLSERVER_AUTH_MODE=windows
SQLSERVER_WINDOWS_AUTH=true
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_TRUST_CERT=yes
SQLSERVER_ENCRYPT=no

# Optional ODBC Authentication keyword. Usually blank.
# Some enterprise/AD environments may require ActiveDirectoryIntegrated.
SQLSERVER_ODBC_AUTHENTICATION=

# Kerberos/keytab configuration. Used only when SQLSERVER_AUTH_MODE=keytab.
# Do not commit real keytab files to source control.
KRB5_CONFIG_PATH=
KRB5_KEYTAB_PATH=
KRB5_PRINCIPAL=
KRB5_CACHE_PATH=
KRB5_KINIT_ENABLED=false
KRB5_KINIT_COMMAND=kinit

ENABLE_DB=false

# Environment-specific DB details.
ENV_LOCAL_SQLSERVER_SERVER=localhost\SQLEXPRESS
ENV_LOCAL_SQLSERVER_DATABASE=PRJ_DB
ENV_LOCAL_SQLSERVER_WINDOWS_AUTH=true
ENV_LOCAL_SQLSERVER_AUTH_MODE=windows
ENV_LOCAL_ENABLE_DB=false

ENV_DEV_SQLSERVER_SERVER=DEV_SQL_SERVER_NAME
ENV_DEV_SQLSERVER_DATABASE=PRJ_DB
ENV_DEV_SQLSERVER_WINDOWS_AUTH=true
ENV_DEV_SQLSERVER_AUTH_MODE=windows
ENV_DEV_ENABLE_DB=true

ENV_UAT_SQLSERVER_SERVER=UAT_SQL_SERVER_NAME
ENV_UAT_SQLSERVER_DATABASE=PRJ_DB
ENV_UAT_SQLSERVER_WINDOWS_AUTH=true
ENV_UAT_ENABLE_DB=true

ENV_PROD_SQLSERVER_SERVER=PROD_SQL_SERVER_NAME
ENV_PROD_SQLSERVER_DATABASE=PRJ_DB
ENV_PROD_SQLSERVER_WINDOWS_AUTH=true
ENV_PROD_ENABLE_DB=true

# Role-based access. Only these users can Create/Edit/Upload Document/Soft Delete/S3 Export.
# Use comma-separated Windows usernames. Example: AMOLJ,DOMAIN\\AMOLJ,sysuser
ADMIN_USERS=*,sysuser
DEFAULT_USER=sysuser
LOCAL_AUTO_ADMIN=true

EXCEL_TEMPLATE_VERSION=1.0
MAX_UPLOAD_SIZE_MB=20

# S3/S3-compatible export configuration.
# This app is configured for internal S3-compatible object storage, not only AWS S3.
# You can use either the S3_* / AWS_* names or the short names below.

# Bucket and path prefix.
S3_BUCKET_NAME=
BUCKET_NAME=
S3_PREFIX=data-dictionary
AWS_REGION=ap-south-1

# Internal object-store endpoint.
# Use the same HOST value that works in your code:
# boto3.client('s3', ..., use_ssl=False, verify=False, endpoint_url=host)
S3_HOST=
HOST=
S3_SECURE_HOST=
SECURE_HOST=
S3_PORT=
S3_ENDPOINT_URL=

# For your internal cloud bucket with self-signed cert chain, keep these false.
# This prevents CERTIFICATE_VERIFY_FAILED errors.
S3_USE_SSL=false
S3_VERIFY_SSL=false
S3_ADDRESSING_STYLE=path

# Credentials. Either pair works.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ACCESS_KEY_ID=
SECRET_KEY=


# Internal S3-compatible object store example
# IMPORTANT: HOST must be only the base endpoint, not bucket/folder path.
# Correct:   HOST=http://internal-s3-host:9000
# Incorrect: HOST=http://internal-s3-host:9000/bucket/folder
BUCKET_NAME=your_bucket_name
HOST=http://your-internal-s3-host:port
SECURE_HOST=https://your-internal-s3-host:port
ACCESS_KEY_ID=your_access_key_id
SECRET_KEY=your_secret_key
S3_USE_SSL=false
S3_VERIFY_SSL=false
S3_ADDRESSING_STYLE=path
S3_PREFIX=data-dictionary


# ------------------------------------------------------------
# SQL Server authentication examples
# ------------------------------------------------------------

# Example 1: Windows Authentication using logged-in user
# SQLSERVER_AUTH_MODE=windows
# SQLSERVER_WINDOWS_AUTH=true
# SQLSERVER_SERVER=localhost\SQLEXPRESS
# SQLSERVER_DATABASE=PRJ_DB

# Example 2: Kerberos keytab authentication for enterprise/Linux service accounts
# SQLSERVER_AUTH_MODE=keytab
# SQLSERVER_WINDOWS_AUTH=true
# SQLSERVER_SERVER=your-sql-server-fqdn
# SQLSERVER_DATABASE=PRJ_DB
# KRB5_CONFIG_PATH=/app/security/krb5.conf
# KRB5_KEYTAB_PATH=/app/security/krb5.keytab
# KRB5_PRINCIPAL=svc_prj_app@YOUR.REALM.COM
# KRB5_CACHE_PATH=/tmp/krb5cc_prj_app
# KRB5_KINIT_ENABLED=true
# KRB5_KINIT_COMMAND=kinit
# SQLSERVER_ODBC_AUTHENTICATION=

# Example 3: SQL username/password authentication
# SQLSERVER_AUTH_MODE=sql
# SQLSERVER_WINDOWS_AUTH=false
# SQLSERVER_USER=your_sql_user
# SQLSERVER_PASSWORD=your_sql_password

# DB authentication modes available in UI: windows, keytab, sql
# Default is SQLSERVER_AUTH_MODE=windows.
